<navigation-bar title="历史" back="{{false}}" color="#111111" background="#FFFFFF" />

<view class="page">
  <view class="hero-card">
    <text class="title">{{pageTitle}}</text>
    <text class="desc">{{pageDesc}}</text>
  </view>

  <view wx:if="{{historyList.length > 0}}" class="history-list">
    <view wx:for="{{historyList}}" wx:key="id" class="history-card">
      <view class="history-head">
        <text class="history-date">{{item.date}}</text>
        <button class="history-delete" data-record-id="{{item.id}}" bindtap="onTapDeleteRecord">
          删除
        </button>
      </view>

      <view class="history-grid">
        <view class="history-metric">
          <text class="metric-label">时长</text>
          <text class="metric-value">{{item.duration}}</text>
        </view>
        <view class="history-metric">
          <text class="metric-label">距离</text>
          <view class="metric-inline">
            <text class="metric-value">{{item.distance}}</text>
            <text class="metric-unit">km</text>
          </view>
        </view>
        <view class="history-metric history-metric--full">
          <text class="metric-label">平均速度</text>
          <view class="metric-inline">
            <text class="metric-value">{{item.averageSpeed}}</text>
            <text class="metric-unit">km/h</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="empty-card">
    <text class="empty-title">{{emptyTitle}}</text>
    <text class="empty-desc">{{emptyDesc}}</text>
  </view>
</view>
